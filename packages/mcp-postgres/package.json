{
  "name": "@loom/mcp-postgres",
  "version": "0.1.0",
  "description": "MCP server exposing any Postgres database as read-only tools (list_tables, describe_table, sample_rows, run_sql) for LLM agents. Drop-in for Claude Code / Claude Desktop.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "loom-mcp-postgres": "./bin/loom-mcp-postgres.js"
  },
