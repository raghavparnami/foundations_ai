# Loom v0.1 environment example. Copy to .env.local and fill in.

# REQUIRED — OpenRouter (https://openrouter.ai/keys). Provides DeepSeek for v0.1.
OPENROUTER_API_KEY=
# Optional override; default is the OpenRouter public endpoint.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OPTIONAL — kept around so we can swap providers without code changes.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Postgres (docker-compose). These defaults match docker-compose.yml.
LOOM_CATALOG_URL=postgres://loom:loom@localhost:5544/loom_catalog
LOOM_DEMO_SOURCE_URL=postgres://loom:loom@localhost:5544/loom_demo_source

# Model selections. OpenRouter slugs.
LOOM_AGENT_MODEL=deepseek/deepseek-chat-v3.1
LOOM_DOC_WRITER_MODEL=deepseek/deepseek-chat-v3.1
