# Loom backend env — copy to .env and edit.
# This service connects to the SAME Postgres as the legacy Next.js app so they
# can run side-by-side until cutover. No schema migrations happen here.

# Catalog DB (Loom's own metadata; foundation_ai schema)
LOOM_CATALOG_URL=postgres://loom:loom@localhost:5544/loom_catalog

# Demo source DB — used by the /connections/inspect smoke test only.
# Real per-connection URLs are stored per row in foundation_ai.sources.
LOOM_DEMO_SOURCE_URL=postgres://loom:loom@localhost:5544/loom_demo_source

# Listen port for uvicorn.  Next.js uses 3001, this service uses 8001.
BACKEND_PORT=8001

# Comma-separated list of allowed CORS origins for the new Vite frontend.
CORS_ORIGINS=http://localhost:5173

# ── LLM provider ───────────────────────────────────────────────────────────
# Pick one: openrouter | databricks. The unselected provider's keys can stay
# blank. Switching providers is a single line change here; no code edits.
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys). Required when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

# Databricks Foundation Model serving. Required when LLM_PROVIDER=databricks.
# DATABRICKS_HOST is the workspace URL (no trailing slash). DATABRICKS_TOKEN
# is a PAT (Settings → Developer → Access tokens). DATABRICKS_MODEL is the
# serving-endpoint name (e.g. databricks-dbrx-instruct,
# databricks-llama-3-1-405b-instruct, or your own custom endpoint).
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_MODEL=databricks-dbrx-instruct
